{
  "name": "canvasight-plugin",
  "version": "0.4.17",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build:mcp": "node scripts/build-mcp.mjs",
    "check:mcp-bundle": "node scripts/build-mcp.mjs --check",
    "release:prepare": "node scripts/prepare-release.mjs",
    "release:verify": "node scripts/prepare-release.mjs --check",
    "dev": "node scripts/dev-server.mjs start",
    "dev:stop": "node scripts/dev-server.mjs stop",
    "dev:status": "node scripts/dev-server.mjs status",
    "dev:foreground": "vite --host 127.0.0.1",
    "daemon": "node mcp/server.mjs --daemon",
    "daemon:stop": "node mcp/server.mjs --stop-daemon",
    "build": "npm run build:mcp && tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview --host 127.0.0.1",
    "test:dev-server": "node tests/dev-server-smoke.mjs",
    "test:markdown": "node tests/markdown-flow-smoke.mjs",
    "test:markdown-export": "node tests/markdown-export-smoke.mjs",
    "test:skills": "node tests/skills-smoke.mjs",
    "test:mcp": "node tests/mcp-smoke.mjs",
    "test:concurrency": "node tests/concurrent-document-smoke.mjs",
    "test:update": "node --test tests/update-canvasight-smoke.mjs",
    "test:plugin-distribution": "node tests/plugin-distribution-smoke.mjs",
    "diagnose:mcp": "node tests/mcp-registration-probe.mjs",
    "test:widget-runtime": "node tests/widget-runtime-smoke.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-switch": "^1.2.6",
    "@xyflow/react": "^12.9.3",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "nanoid": "^5.1.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "vite": "^7.2.6",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  }
}
